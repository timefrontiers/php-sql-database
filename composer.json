{
  "name": "timefrontiers/php-sql-database",
  "description": "PHP SQL Database manager supporting MySQLi and PDO with backward compatibility",
  "keywords": ["php", "sql", "database", "mysqli", "pdo", "mysql"],
  "homepage": "https://github.com/timefrontiers/php-sql-database",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Ikechukwu Okalia",
      "email": "consult@ikechukwuokalia.dev",
      "homepage": "https://ikechukwuokalia.dev",
      "role": "developer"
    },
    {
      "name": "Time Frontiers Ltd",
      "email": "git@timefrontiers.com",
      "homepage": "https://timefrontiers.com",
      "role": "developer"
    }
  ],
  "require": {
    "php": ">=8.1",
    "ext-mysqli": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "suggest": {
    "ext-pdo": "For PDO database support",
    "ext-pdo_mysql": "For MySQL PDO support",
    "ext-pdo_pgsql": "For PostgreSQL PDO support"
  },
  "autoload": {
    "psr-4": {
      "TimeFrontiers\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "TimeFrontiers\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}